# adjust the sampling function
def sample_kde(kde_residuals, x_test, A_param, Sigma_param, n_samples=1):

    conditional_mean = A_param @ x_test.T
    conditional_mean = conditional_mean.reshape(1, -1) # 调整维度
    conditional_cov = Sigma_param

    # sample from the standardizedresiduals
    standardized_residuals = kde_residuals.data
    n_residuals = len(standardized_residuals)

    random_indices = np.random.randint(0, n_residuals, size=n_samples)
    standardized_samples = standardized_residuals[random_indices] + \
                          kde_residuals.bw * np.random.randn(n_samples, 2)

    L = np.linalg.cholesky(conditional_cov)
    samples = conditional_mean + standardized_samples @ L.T

    return samples


def eval_kde_wd(kde_residuals, x_grid, A, Sigma, A_param, Sigma_param, m=200, random_state=42):

    np.random.seed(random_state)
    distances = {'kde': {'q1': [], 'q2': [], 'q3': []}}

    for x0 in x_grid:
        # P0
        mean_true = np.squeeze(A @ x0.T)
        cov_true = Sigma
        Y_true = np.random.multivariate_normal(mean_true, cov_true, size=m)

        # KDE sampling
        Y_kde = sample_kde(kde_residuals, x0, A_param, Sigma_param, m)

        # transport the samples
        Y_true_results = transport(Y_true, nR=40, nS=25, d=2, verbose=False)
        Y_kde_results = transport(Y_kde, nR=40, nS=25, d=2, verbose=False)

        # rank point
        Y_true_q1 = Y_true_results['q1_points']
        Y_kde_q1 = Y_kde_results['q1_points']

        Y_true_q2 = Y_true_results['q2_points']
        Y_kde_q2 = Y_kde_results['q2_points']

        Y_true_q3 = Y_true_results['q3_points']
        Y_kde_q3 = Y_kde_results['q3_points']

        # Wasserstein-2
        m_adj = len(Y_true_q1)

        a = np.ones(m_adj) / m_adj
        b = np.ones(m_adj) / m_adj

        # ==================== q1 ====================
        M_kde_q1 = ot.dist(Y_true_q1, Y_kde_q1, metric='euclidean')**2
        W2_sq_kde_q1 = ot.emd2(a, b, M_kde_q1)
        distances['kde']['q1'].append(np.sqrt(W2_sq_kde_q1))

        # ==================== q2 ====================
        M_kde_q2 = ot.dist(Y_true_q2, Y_kde_q2, metric='euclidean')**2
        W2_sq_kde_q2 = ot.emd2(a, b, M_kde_q2)
        distances['kde']['q2'].append(np.sqrt(W2_sq_kde_q2))

        # ==================== q3 ====================
        M_kde_q3 = ot.dist(Y_true_q3, Y_kde_q3, metric='euclidean')**2
        W2_sq_kde_q3 = ot.emd2(a, b, M_kde_q3)
        distances['kde']['q3'].append(np.sqrt(W2_sq_kde_q3))

    for method in distances:
        for quantile in distances[method]:
            distances[method][quantile] = np.array(distances[method][quantile])

    return distances

from statsmodels.nonparametric.kernel_density import KDEMultivariate


def evaluate_bandwidth_sensitivity(data_train, A_param, Sigma_param,
                                       X_val, A, Sigma,
                                       bandwidth_multipliers=[0.5, 1.0, 2.0, 4.0, 8.0],
                                       n_test_points=20,
                                       n_samples=1000,
                                       random_state=42):

    # extract 10 points from validation set
    np.random.seed(random_state)
    n_val = len(X_val)
    test_indices = np.random.choice(n_val, size=n_test_points, replace=False)

    # x_grid
    x_grid = [X_val[idx] for idx in test_indices]

    # standardized residuals
    standardized_residuals = calculate_residuals(data_train, A_param, Sigma_param)

    # reference bandwidth h0
    print("compute the bandwidth (h0) using 'normal_reference'")
    kde_reference = KDEMultivariate(standardized_residuals,
                                    bw='normal_reference',
                                    var_type='cc')
    h0 = kde_reference.bw 
    print(f"bandwidth h0 = {h0}")

    results = {
        'bandwidth_multipliers': bandwidth_multipliers,
        'h0': h0,
        'bandwidth_values': [],  # real bandwidth
        'means': {'q1': [], 'q2': [], 'q3': []},
        'stds': {'q1': [], 'q2': [], 'q3': []},
        'all_distances': {}
    }

    for multiplier in bandwidth_multipliers:
        print(f"\n{'='*50}")
        print(f"Testing Bandwidth = {multiplier} * h0 = {multiplier} * {h0}")
        print(f"{'='*50}")

        if isinstance(h0, (list, np.ndarray)):
            bw_actual = [multiplier * bw for bw in h0]
        else:
            bw_actual = multiplier * h0

        results['bandwidth_values'].append(bw_actual)

        # specific bandwidth for KDE
        kde_residuals = KDEMultivariate(standardized_residuals,
                                        bw=bw_actual,
                                        var_type='cc')

        # WD
        distances = eval_kde_wd(
            kde_residuals=kde_residuals,
            x_grid=x_grid,
            A=A,
            Sigma=Sigma,
            A_param=A_param,
            Sigma_param=Sigma_param,
            m=n_samples,
            random_state=random_state
        )

        results['all_distances'][multiplier] = distances['kde']

        # cumpute mean & standard error for each quantile
        for quantile in ['q1', 'q2', 'q3']:
            wd_list = distances['kde'][quantile]
            mean_wd = np.mean(wd_list)
            std_wd = np.std(wd_list)

            results['means'][quantile].append(mean_wd)
            results['stds'][quantile].append(std_wd)

            print(f"  {quantile}: Mean WD={mean_wd:.4f}, Std WD={std_wd:.4f}")

    return results


