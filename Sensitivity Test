# MDN
# K - component of mdn

def eval_k_wd(gmm_model, x_grid, A, Sigma, A_param, Sigma_param, m=200, random_state=42):

    np.random.seed(random_state)
    #rng = np.random.default_rng(random_state)
    distances = {
        'mdn': {'q1': [], 'q2': [], 'q3': []}}

    for x0 in x_grid:

        # P0
        mean_true = np.squeeze(A @ x0.T)
        cov_true = Sigma
        Y_true = np.random.multivariate_normal(mean_true, cov_true, size=m)

        # mdn P3
        gmm = gmm_model.predict_model(x0)
        Y_mdn = gmm.sample(m)

        # transport the samples
        Y_true_results = transport(Y_true, nR=40, nS=25, d=2, verbose=False)
        Y_mdn_results = transport(Y_mdn, nR=40, nS=25, d=2, verbose=False)

        # rank point
        Y_true_q1 = Y_true_results['q1_points']
        Y_mdn_q1 = Y_mdn_results['q1_points']

        Y_true_q2 = Y_true_results['q2_points']
        Y_mdn_q2 = Y_mdn_results['q2_points']

        Y_true_q3 = Y_true_results['q3_points']
        Y_mdn_q3 = Y_mdn_results['q3_points']

        # Wasserstein-2
        m_adj = len(Y_true_q1) 

        a = np.ones(m_adj) / m_adj
        b = np.ones(m_adj) / m_adj

        # ==================== q1 ====================
        M_mdn_q1 = ot.dist(Y_true_q1, Y_mdn_q1, metric='euclidean')**2
        W2_sq_mdn_q1 = ot.emd2(a, b, M_mdn_q1)
        distances['mdn']['q1'].append(np.sqrt(W2_sq_mdn_q1))

        # ==================== q2 ====================
        M_mdn_q2 = ot.dist(Y_true_q2, Y_mdn_q2, metric='euclidean')**2
        W2_sq_mdn_q2 = ot.emd2(a, b, M_mdn_q2)
        distances['mdn']['q2'].append(np.sqrt(W2_sq_mdn_q2))

        # ==================== q3 ====================
        M_mdn_q3 = ot.dist(Y_true_q3, Y_mdn_q3, metric='euclidean')**2
        W2_sq_mdn_q3 = ot.emd2(a, b, M_mdn_q3)
        distances['mdn']['q3'].append(np.sqrt(W2_sq_mdn_q3))

    for method in distances:
      for quantile in distances[method]:
        distances[method][quantile] = np.array(distances[method][quantile])

    return distances


def evaluate_k_sensitivity(X_train, y_train, X_val, y_val,
                          A, Sigma, A_param, Sigma_param,
                          k_values=[5, 10, 15, 20, 30],
                          n_test_points=10,
                          n_samples=1000,
                          random_state=42):


    # extract 10 points from validation set
    np.random.seed(random_state)
    n_val = len(X_val)
    test_indices = np.random.choice(n_val, size=n_test_points, replace=False)

    #x_grid
    x_grid = [X_val[idx] for idx in test_indices]
    results = {
        'k_values': k_values,
        'means': {'q1': [], 'q2': [], 'q3': []},
        'stds': {'q1': [], 'q2': [], 'q3': []},
        'all_distances': {}
    }

    for k in k_values:
        print(f"\n{'='*50}")
        print(f"Testing K={k}...")
        print(f"{'='*50}")

        # model training
        torch.set_default_dtype(torch.float64)
        model = RNN(gause_mixture_n=k)
        model, tl, vl = train(model, X_train, y_train, X_val, y_val, lr=3e-4, batch_size=128, epochs=10)

        # WD
        distances = eval_k_wd(
            gmm_model=model,  
            x_grid=x_grid,
            A=A,
            Sigma=Sigma,
            A_param=A_param,
            Sigma_param=Sigma_param,
            m=n_samples,
            random_state=random_state
        )

        # save distances
        results['all_distances'][k] = distances['mdn']

        # cumpute mean & standard error for each quantile
        for quantile in ['q1', 'q2', 'q3']:
            wd_list = distances['mdn'][quantile]
            mean_wd = np.mean(wd_list)
            std_wd = np.std(wd_list)

            results['means'][quantile].append(mean_wd)
            results['stds'][quantile].append(std_wd)

            print(f"  {quantile}: Mean WD={mean_wd:.4f}, Std WD={std_wd:.4f}")

    return results


